RewriteEngine On

# Stop if the request is for an existing file or folder
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pretty URLs for MovieMate
# (no RewriteBase needed on InfinityFree usually)

# /start-session       → start-session.php
RewriteRule ^start-session/?$ start-session.php [L,QSA]

# /m/<session>         → join.php?session=<session>
RewriteRule ^m/([a-f0-9]{16})/?$ join.php?session=$1 [L,QSA]

# /m/<session>/a       → choose.php?session=<session>&who=A
RewriteRule ^m/([a-f0-9]{16})/a/?$ choose.php?session=$1&who=A [L,QSA]

# /m/<session>/b       → choose.php?session=<session>&who=B
RewriteRule ^m/([a-f0-9]{16})/b/?$ choose.php?session=$1&who=B [L,QSA]

# /m/<session>/match   → match.php?session=<session>
RewriteRule ^m/([a-f0-9]{16})/match/?$ match.php?session=$1 [L,QSA]

# /m/<session>/save    → save-choices.php?session=<session>
RewriteRule ^m/([a-f0-9]{16})/save/?$ save-choices.php?session=$1 [L,QSA]

# /m/<session>/status  → session-status.php?session=<session>
RewriteRule ^m/([a-f0-9]{16})/status/?$ session-status.php?session=$1 [L,QSA]
